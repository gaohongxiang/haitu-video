NODE_ENV=production
HAITU_HOST=127.0.0.1
HAITU_PORT=4173
HAITU_DATA_DIR=/var/lib/haitu-video

# Set this on VPS before exposing haitu.online. Leave empty only for local development.
HAITU_AUTH_PASSWORD=

# Keep paid provider keys out of git. Put the real key in /etc/haitu-video.env
# or save a local BYOK key from the console after login is added.
ARK_API_KEY=
SEEDANCE_API_KEY=
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com
SEEDANCE_MODEL=doubao-seedance-2-0-260128
SEEDANCE_RESOLUTION=480p
SEEDANCE_WATERMARK=false
SEEDANCE_POLL_MS=5000
SEEDANCE_MAX_POLLS=120
SEEDANCE_ESTIMATED_COST_CNY_PER_SECOND=0.8
SEEDANCE_ESTIMATED_COST_CURRENCY=CNY
