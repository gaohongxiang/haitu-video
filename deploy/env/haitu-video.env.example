NODE_ENV=production
HAITU_HOST=127.0.0.1
HAITU_PORT=4173
HAITU_DATA_DIR=/var/lib/haitu-video
HAITU_DB_PATH=/var/lib/haitu-video/haitu.sqlite
HAITU_SECRET_KEY=replace-with-at-least-32-random-bytes
HAITU_ADMIN_EMAIL=
BETTER_AUTH_URL=https://haitu.online
HAITU_AUTH_EMAIL_FROM=
RESEND_API_KEY=

# Platform-provided API keys. These stay server-side in /etc/haitu-video.env.
# Users who bring their own keys configure those in API 管理 after login.
HAITU_PLATFORM_OPENAI_API_KEY=
HAITU_PLATFORM_DEEPSEEK_API_KEY=
HAITU_PLATFORM_DOUBAO_API_KEY=
HAITU_PLATFORM_GEMINI_API_KEY=
HAITU_PLATFORM_VOLCENGINE_API_KEY=
HAITU_PLATFORM_DEFAULT_TEXT_MODEL=deepseek-v4-pro
HAITU_PLATFORM_DEFAULT_IMAGE_MODEL=gpt-image-2
HAITU_PLATFORM_DEFAULT_VIDEO_MODEL=seedance-2.0-fast
HAITU_PLATFORM_FEE_CNY_PER_TEXT=0.2
HAITU_PLATFORM_FEE_CNY_PER_IMAGE=0.3
HAITU_PLATFORM_FEE_CNY_PER_VIDEO=1
SEEDANCE_RESOLUTION=480p
SEEDANCE_WATERMARK=false
SEEDANCE_POLL_MS=5000
SEEDANCE_MAX_POLLS=120
SEEDANCE_ESTIMATED_COST_CNY_PER_SECOND=0.8
SEEDANCE_ESTIMATED_COST_CURRENCY=CNY
