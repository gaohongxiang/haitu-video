NODE_ENV=production
HAITU_HOST=127.0.0.1
HAITU_PORT=4173
HAITU_DATA_DIR=/var/lib/haitu-video
HAITU_DB_PATH=/var/lib/haitu-video/haitu.sqlite
HAITU_SECRET_KEY=replace-with-at-least-32-random-bytes
HAITU_ADMIN_EMAIL=
HAITU_PUBLIC_BASE_URL=https://haitu.online
BETTER_AUTH_URL=https://haitu.online
HAITU_AUTH_EMAIL_FROM=
RESEND_API_KEY=

# Wallet recharge providers.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
INFINI_ENV=sandbox
INFINI_PUBLIC_KEY=
INFINI_PRIVATE_KEY=
INFINI_WEBHOOK_SECRET=

# Optional pricing overrides. Platform model API keys are configured in /admin
# and stored encrypted in SQLite, not in this env file.
HAITU_PLATFORM_FEE_CNY_PER_TEXT=0.2
HAITU_PLATFORM_FEE_CNY_PER_IMAGE=0.3
HAITU_PLATFORM_FEE_CNY_PER_VIDEO=1
SEEDANCE_RESOLUTION=480p
SEEDANCE_WATERMARK=false
SEEDANCE_POLL_MS=5000
SEEDANCE_MAX_POLLS=120
SEEDANCE_ESTIMATED_COST_CNY_PER_SECOND=0.8
SEEDANCE_ESTIMATED_COST_CURRENCY=CNY
