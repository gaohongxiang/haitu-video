# Copy this file to `.env` and fill in your real values.
# `.env` is ignored by git.

# Platform-provided API keys. These are server-only and never exposed to users.
# Leave blank in BYOK-only local development.
HAITU_PLATFORM_OPENAI_API_KEY=
HAITU_PLATFORM_DEEPSEEK_API_KEY=
HAITU_PLATFORM_DOUBAO_API_KEY=
HAITU_PLATFORM_GEMINI_API_KEY=
HAITU_PLATFORM_VOLCENGINE_API_KEY=

# Optional platform model selection. Friendly labels from the built-in catalog also work.
HAITU_PLATFORM_DEFAULT_TEXT_MODEL=deepseek-v4-pro
HAITU_PLATFORM_DEFAULT_IMAGE_MODEL=gpt-image-2
HAITU_PLATFORM_DEFAULT_VIDEO_MODEL=seedance-2.0-fast

# Optional runtime defaults for Volcengine Seedance.
SEEDANCE_RESOLUTION=480p
SEEDANCE_WATERMARK=false
SEEDANCE_POLL_MS=5000
SEEDANCE_MAX_POLLS=120
SEEDANCE_ESTIMATED_COST_CNY_PER_SECOND=0.8
SEEDANCE_ESTIMATED_COST_CURRENCY=CNY
