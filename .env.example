# Copy this file to `.env` and fill in real server-only values.
# Keep `.env` out of git.

# Required core runtime.
HAITU_SECRET_KEY=replace-with-at-least-32-random-bytes
BETTER_AUTH_URL=https://haitu.online
HAITU_DATA_DIR=/var/lib/haitu-video

# Optional admin and login email delivery.
HAITU_ADMIN_EMAIL=
HAITU_AUTH_EMAIL_FROM=
RESEND_API_KEY=

# Wallet recharge order policy. Stripe accepts 1800-86400 seconds; Infini receives this as expires_in.
HAITU_RECHARGE_ORDER_EXPIRES_IN_SECONDS=3600

# Recharge FX quote policy. Defaults to Frankfurter live rates and stores each order's quote snapshot.
# Set HAITU_RECHARGE_FX_RATE_PROVIDER=env only when you want to force manual fixed rates.
HAITU_RECHARGE_FX_RATE_PROVIDER=frankfurter
HAITU_RECHARGE_FX_RATE_URL=https://api.frankfurter.dev/v2/rates
# Optional fallback/manual override for non-CNY provider currencies.
HAITU_RECHARGE_USD_PER_CNY=
HAITU_RECHARGE_HKD_PER_CNY=

# Stripe wallet recharge. Use test-mode keys first, then switch to live keys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional. Defaults to cny. If set to hkd/usd, the payment amount uses the FX quote above.
STRIPE_CURRENCY=cny

# Infini Hosted Checkout for crypto wallet recharge.
INFINI_ENV=sandbox/production
INFINI_PUBLIC_KEY=
INFINI_PRIVATE_KEY=
INFINI_WEBHOOK_SECRET=
# Optional. Defaults to usd because Infini Hosted Checkout may not support CNY order currency.
INFINI_CURRENCY=usd
