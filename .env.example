# Copy this file to `.env` and fill in your real values.
# `.env` is ignored by git.

# Use either ARK_API_KEY or SEEDANCE_API_KEY.
ARK_API_KEY=

# Optional overrides. Keep defaults unless your console shows different values.
SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com
SEEDANCE_MODEL=doubao-seedance-2-0-fast-260128
SEEDANCE_RESOLUTION=480p
SEEDANCE_WATERMARK=false
SEEDANCE_POLL_MS=5000
SEEDANCE_MAX_POLLS=120
SEEDANCE_ESTIMATED_COST_CNY_PER_SECOND=0.8
SEEDANCE_ESTIMATED_COST_CURRENCY=CNY
